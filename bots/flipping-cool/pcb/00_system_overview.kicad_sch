  (paper "A4")
  (title_block
    (title "Flipping Cool Rev B - System Overview")
    (date "2026-05-09")
    (rev "B")
    (company "battle_bots_ai")
  )
  (lib_symbols
  )
  (text "Flipping Cool Rev B single-board integrated control/power design"
    (at 15.00 16.00 0)
    (effects (font (size 1.80 1.80)) (justify left top))
    (uuid "98dab426-513d-59ea-815e-80de74ba4184")
  )
  (text "Off-board boundary (intentional): 2S battery pack, WEKA dual brushed ESC, 4 drive motors, 2 weapon servos, Matek ELRS-R24-P6 receiver."
    (at 15.00 24.00 0)
    (effects (font (size 1.27 1.27)) (justify left top))
    (uuid "91f456d7-633f-5e46-b67c-230e8660950c")
  )
  (text "Power tree: J1 battery -> J2 removable link -> VBAT_SW. VBAT_SW feeds U20 6V servo buck, U21 RX_5V regulator, U30 AUX_3V3 buck, D1 TVS, C1/C2 bulk, and test points."
    (at 15.00 34.00 0)
    (effects (font (size 1.27 1.27)) (justify left top))
    (uuid "b119da12-fe53-5afd-abcd-1850b0a4284a")
  )
  (text "Receiver-priority authority model (hardware-enforced):"
    (at 15.00 45.00 0)
    (effects (font (size 1.27 1.27) bold yes) (justify left top))
    (uuid "0c2b6c44-91ab-50f2-a178-ca32f5bd105d")
  )
  (text "SAFE: MODE_SAFE high, MODE_RX_DIRECT low, MODE_MCU_CONTROL low. SERVO_6V_SW disabled through Q1 load switch. PWM mux defaults to receiver side while servo rail is cut."
    (at 15.00 51.00 0)
    (effects (font (size 1.05 1.05)) (justify left top))
    (uuid "ac45a776-0bfd-59ba-8175-8d2d23b6c3f4")
  )
  (text "RX_DIRECT: MODE_RX_DIRECT high. SERVO_6V_SW enabled. PWM mux select forced to receiver channel inputs. Works with MCU absent or crashed."
    (at 15.00 59.00 0)
    (effects (font (size 1.05 1.05)) (justify left top))
    (uuid "ee831889-fe2e-5a36-bb40-194c701f5639")
  )
  (text "MCU_CONTROL: MODE_MCU_CONTROL high. SERVO_6V_SW enabled. PWM mux select switches to ESP32-S3 outputs. BLE/firmware authority only in this state."
    (at 15.00 67.00 0)
    (effects (font (size 1.05 1.05)) (justify left top))
    (uuid "e51f1d0d-8a69-5387-ae51-557df93f4b50")
  )
  (text "Critical safety wiring: MODE_SAFE/MODE_RX_DIRECT/MODE_MCU_CONTROL each have 100k pull-downs, so undefined switch travel cannot float authority nets."
    (at 15.00 75.00 0)
    (effects (font (size 1.05 1.05)) (justify left top))
    (uuid "ec5f4be7-5750-49be-a567-0c56d94e39d5")
  )
  (text "Rail naming contract: VBAT_RAW before disconnect, VBAT_SW after link, SERVO_6V from U20, SERVO_6V_SW after Q1, RX_5V from U21, AUX_3V3 from U30, GND_PWR common return."
    (at 15.00 84.00 0)
    (effects (font (size 1.05 1.05)) (justify left top))
    (uuid "212de4cd-d7e6-4ea6-9f2d-0ee8fafe5ec8")
  )
  (text "Validated source set: Pololu 3064 motors, Savox SH-0255MG+, GNB 2S LiHV 450mAh pack, Matek ELRS-R24-P6, WEKA dual brushed ESC, Pololu D36V50F6."
    (at 15.00 95.00 0)
    (effects (font (size 1.00 1.00)) (justify left top))
    (uuid "6fdf18e1-194c-4529-b0d2-30ee33bb2143")
  )
  (text "Rev B implementation rule: this schematic is authoritative. PCB must stay synchronized from this source before any routing or fab release."
    (at 15.00 104.00 0)
    (effects (font (size 1.05 1.05) bold yes) (justify left top))
    (uuid "dc2b1a4a-c5c9-437b-9586-c8cf8af8c3be")
  )
